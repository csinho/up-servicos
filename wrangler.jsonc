{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "freela-os",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "triggers": {
    "crons": ["0 12 * * *"]
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "PUBLIC_APP_URL": "https://upservicos.com"
  }
}
