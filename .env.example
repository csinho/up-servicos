# Copie para .env na máquina local (não commitar o .env).
# Produção: secrets no GitHub Actions + Cloudflare Worker (ver docs/DEPLOY-CLOUDFLARE.md).

# URL do projeto Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://tdtmxddukuqsxsiiwzqp.supabase.co

# Chave pública (Settings → API → publishable key ou anon key legada)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sV6Tal25v-z7Def-bEPV1A_v5IpDrpr

# --- Server-only (NÃO prefixar VITE_; não expor no frontend) ---

# Service role (Settings → API → service_role — só no servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Woovi/OpenPix — AppID da API (sem Bearer, sem aspas)
WOOVI_APP_ID=

# Ou montar AppID: Base64(clientId:clientSecret)
# WOOVI_CLIENT_ID=
# WOOVI_CLIENT_SECRET=

# URL pública do app (links em notificações)
PUBLIC_APP_URL=https://seu-dominio.com

# Protege GET /api/cron/billing
BILLING_CRON_SECRET=

# Opcional: header Authorization no webhook (só se configurar no painel Woovi)
# WOOVI_WEBHOOK_AUTHORIZATION=

# Opcional: override da base URL Woovi
# WOOVI_API_URL=https://api.openpix.com.br/api/v1

# Painel admin — WhatsApps autorizados (11 dígitos, separados por vírgula)
ADMIN_WHATSAPP_ALLOWLIST=71996755745

# Evolution API — OTP WhatsApp (cadastro + login)
EVOLUTION_API_URL=https://whats.seudominio.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=erp-up-servicos-dev
# EVOLUTION_MOCK=true  # dev: OTP no toast, sem WhatsApp real
